{
  "manifest_version": 3,
  "name": "Backlink Outreach Capture",
  "version": "1.0.0",
  "description": "Capture guest post opportunities and contacts while browsing. Saves to your local Outreach Tool.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://localhost:3847/*",
    "https://azbuilds.xyz/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save outreach opportunity"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
